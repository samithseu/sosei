---
import LayoutPrint from "../layouts/LayoutPrint.astro";
import PageHeader from "../components/print/PageHeader.astro";
import PageFooter from "../components/print/PageFooter.astro";
import TopLeft from "../components/print/TopLeft.astro";
import TopCenter from "../components/print/TopCenter.astro";
import TopRight from "../components/print/TopRight.astro";
import BottomLeft from "../components/print/BottomLeft.astro";
import BottomCenter from "../components/print/BottomCenter.astro";
import BottomRight from "../components/print/BottomRight.astro";
import PageNumber from "../components/print/PageNumber.astro";
---

<LayoutPrint title="Home">
  <!-- Header: Appears on all pages -->
  <PageHeader slot="header">
    <TopLeft>
      <span class="company-name">SoSei - សរសេរ</span>
    </TopLeft>
    <TopCenter>
      <span class="document-title">Quick Intro</span>
    </TopCenter>
    <TopRight>
      <span class="highlight-badge">SAMPLE HEADER</span>
    </TopRight>
  </PageHeader>

  <!-- Footer: Appears on all pages -->
  <PageFooter slot="footer">
    <BottomLeft>
      <span class="draft-notice">SAMPLE FOOTER</span>
    </BottomLeft>
    <BottomCenter>
      <span class="page-info"
        >Page <PageNumber /> of <span class="total-pages"></span></span
      >
    </BottomCenter>
    <BottomRight>
      <span id="footer-date" class="date"></span>
    </BottomRight>
  </PageFooter>

  <!-- Main Content -->
  <article class="document">
    <header class="intro-header">
      <h1>SoSei - សរសេរ</h1>
      <p class="tagline">
        A template for creating beautiful PDFs with HTML & CSS
      </p>
      <a
        href="https://github.com/samithseu/sosei"
        class="github-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        View on GitHub →
      </a>
    </header>

    <section>
      <h2>Overview</h2>
      <p>
        This document demonstrates the print component system for the <code
          >SoSei</code
        >
        project. The header and footer components automatically appear on every page,
        with support for page range restrictions.
      </p>
    </section>

    <section>
      <h2>Features</h2>
      <ul>
        <li>
          <strong><code>PageHeader</code> & <code>PageFooter</code></strong> - Running
          headers and footers on every page
        </li>
        <li>
          <strong>Positioning Components</strong> - <code>TopLeft</code>, <code
            >TopCenter</code
          >, <code>TopRight</code>, <code>BottomLeft</code>, <code
            >BottomCenter</code
          >, <code>BottomRight</code>
        </li>
        <li>
          <strong><code>PageNumber</code></strong> - Automatic page numbering with
          current/total display
        </li>
      </ul>
    </section>

    <section>
      <h2>Quick Start</h2>
      <p>
        Get started in minutes. Clone the repository and edit <code
          >src/pages/index.astro</code
        > to create your PDF.
      </p>

      <div class="quick-start-flow">
        <div class="step-card">
          <span class="step-number">1</span>
          <div class="step-content">
            <div class="step-header">
              <h4>Clone</h4>
              <button
                class="copy-btn"
                data-copy="git clone https://github.com/samithseu/sosei.git"
                title="Copy to clipboard"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><rect width="14" height="14" x="8" y="8" rx="2" ry="2"
                  ></rect><path
                    d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                  ></path></svg
                >
              </button>
            </div>
            <pre><code>git clone https://github.com/samithseu/sosei.git</code></pre>
          </div>
        </div>
        <div class="step-card">
          <span class="step-number">2</span>
          <div class="step-content">
            <h4>Edit</h4>
            <p class="step-desc">
              Open <code>src/pages/index.astro</code> and customize the content. Then
              press Ctrl+P to print to PDF.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2>Customization</h2>
      <p>
        <code>SoSei</code> is built with customization in mind. All components use
        scoped CSS, making it easy to override styles for your specific needs. Modify
        colors, fonts, spacing, and layout through CSS custom properties or component
        styles.
      </p>
      <p>
        The template uses modern CSS features including Grid, Flexbox, and
        logical properties. This ensures your documents look great both on
        screen and in print.
      </p>
    </section>

    <section>
      <h2>Project Structure</h2>
      <p>
        The template follows a clean organization pattern with components,
        layouts, and pages separated into logical directories. All
        print-specific components are located in <code
          >src/components/print/</code
        > for easy discovery and reuse.
      </p>
    </section>

    <section>
      <h2>Next Steps</h2>
      <p>
        Ready to create your own PDFs? Start by exploring the example components
        in this template, then customize them to match your brand and
        requirements. Check out the GitHub repository for more examples and
        documentation.
      </p>
    </section>
  </article>
</LayoutPrint>

<style>
  .document {
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    line-height: 1.5;
    color: #333;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #1a1a1a;
    text-align: center;
    letter-spacing: -0.02em;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #2d2d2d;
  }

  h3,
  h4 {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
    color: #444;
  }

  .intro-header {
    text-align: center;
    padding: 2rem 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .intro-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0.25rem;
    background: linear-gradient(135deg, #1a1a1a 0%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.03em;
  }

  .tagline {
    text-align: center;
    text-wrap: balance;
    font-size: 1rem;
    color: #666;
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .github-link {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: #1a1a1a;
    color: white;
    text-decoration: none;
    border-radius: 0.375rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .github-link:hover {
    background-color: var(--color-primary);
    transform: translateY(-1px);
  }

  p {
    margin-bottom: 0.6rem;
    text-align: justify;
  }

  ul {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
  }

  li {
    margin-bottom: 0.35rem;
  }

  .quick-start-flow {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0.75rem 0;
    position: relative;
  }

  .quick-start-flow::before {
    content: "";
    position: absolute;
    left: 0.875rem;
    top: 1.5rem;
    bottom: 1.5rem;
    width: 2px;
    background: linear-gradient(
      to bottom,
      mediumslateblue 0%,
      mediumslateblue calc(100% - 2rem),
      transparent calc(100% - 2rem)
    );
  }

  .step-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
    position: relative;
    background: transparent;
    border: none;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: mediumslateblue;
    color: white;
    border-radius: 50%;
    font-size: 0.875rem;
    font-weight: 700;
    flex-shrink: 0;
    z-index: 1;
  }

  .step-content {
    flex: 1;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 0.375rem;
    padding: 0.75rem 1rem;
  }

  .step-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .step-content h4 {
    margin: 0;
    font-size: 0.9375rem;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    background: mediumslateblue;
    color: white;
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 0.2s,
      background-color 0.2s;
  }

  .step-content:hover .copy-btn {
    opacity: 0.9;
  }

  .copy-btn:hover {
    opacity: 1 !important;
  }

  .copy-btn.copied {
    opacity: 1 !important;
    background: #22c55e;
  }

  .step-card pre {
    margin: 0;
    padding: 0.5rem 0.625rem;
    font-size: 0.8125rem;
    background: white;
    border-left: 2px solid mediumslateblue;
    border-radius: 0;
    line-height: 1.4;
  }

  .step-card .step-desc {
    font-size: 0.8125rem;
    margin: 0;
    text-align: left;
  }

  pre {
    background-color: #f5f5f5;
    padding: 0.75rem;
    border-radius: 0.375rem;
    overflow-x: auto;
    font-size: 0.8rem;
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }

  :not(pre) > code {
    font-family: "Monaco", "Menlo", "Ubuntu Mono", monospace;
    background-color: rgba(147, 112, 219, 0.1);
    color: mediumslateblue;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  section {
    break-inside: auto;
  }

  /* Scoped styles for header/footer content */
  .company-name {
    font-weight: 600;
    color: #333;
  }

  .document-title {
    font-weight: 500;
    color: #666;
  }

  .highlight-badge {
    background-color: var(--color-primary);
    color: white;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-weight: bold;
    border-radius: 0.25rem;
  }

  .draft-notice {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.75rem;
  }

  .page-info {
    font-size: 0.875rem;
    color: #666;
  }

  .date {
    font-size: 0.875rem;
    color: #666;
  }
</style>

<script is:inline>
  // getting current date for footer
  document.querySelector("#footer-date").innerText =
    new Date().toLocaleDateString();

  // Copy button functionality - use event delegation
  document.addEventListener("click", async (e) => {
    const btn = e.target.closest(".copy-btn");
    if (!btn) return;

    e.preventDefault();
    const text = btn.dataset.copy;

    try {
      await navigator.clipboard.writeText(text);

      // Show checkmark icon
      const originalIcon = btn.innerHTML;
      btn.innerHTML =
        '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
      btn.classList.add("copied");

      setTimeout(() => {
        btn.innerHTML = originalIcon;
        btn.classList.remove("copied");
      }, 2000);
    } catch (err) {
      console.error("Failed to copy:", err);
    }
  });
</script>
