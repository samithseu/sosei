---
interface Props {
  pageRange?: string;
}

const { pageRange } = Astro.props;
---

<div
  class="top-center"
  data-page-range={pageRange}
>
  <slot />
</div>

<style>
  .top-center {
    grid-area: center;
    justify-self: center;
    text-align: center;
    /* Constrain to header bounds */
    max-width: 100%;
    overflow: hidden;
  }
</style>
