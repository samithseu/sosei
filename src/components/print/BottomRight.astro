---
interface Props {
  pageRange?: string;
}

const { pageRange } = Astro.props;
---

<div
  class="bottom-right"
  data-page-range={pageRange}
>
  <slot />
</div>

<style>
  .bottom-right {
    grid-area: right;
    justify-self: end;
    text-align: right;
    white-space: normal;
    overflow-wrap: break-word;
  }
</style>
