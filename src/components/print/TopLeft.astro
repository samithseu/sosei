---
interface Props {
  pageRange?: string;
}

const { pageRange } = Astro.props;
---

<div class="top-left" data-page-range={pageRange}>
  <slot />
</div>

<style>
  .top-left {
    grid-area: left;
    justify-self: start;
    text-align: left;
    white-space: normal;
    overflow-wrap: break-word;
  }
</style>
