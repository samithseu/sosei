---
interface Props {
  pageRange?: string;
}

const { pageRange } = Astro.props;
---

<div class="page-header" data-page-range={pageRange}>
  <slot />
</div>

<style>
  .page-header {
    position: running(page-header);
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-areas: "left center right";
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid #e5e5e5;
    font-size: 0.875rem;
    color: #666;
  }

  /* Ensure children stay within grid areas */
  .page-header :global(*) {
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
