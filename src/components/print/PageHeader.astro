---
interface Props {
  pageRange?: string;
}

const { pageRange } = Astro.props;
---

<div class="page-header custom-header" data-page-range={pageRange}>
  <slot />
</div>

<style>
  .page-header {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-areas: "left center right";
    align-items: end;
    padding: 0.5rem 0;
    border-bottom: 1px solid #e5e5e5;
    font-size: 0.875rem;
    color: #666;
    box-sizing: border-box;
  }
</style>
