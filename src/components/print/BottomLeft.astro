---
interface Props {
  pageRange?: string;
}

const { pageRange } = Astro.props;
---

<div
  class="bottom-left"
  data-page-range={pageRange}
>
  <slot />
</div>

<style>
  .bottom-left {
    grid-area: left;
    justify-self: start;
    text-align: left;
    /* Constrain to footer bounds */
    max-width: 100%;
    overflow: hidden;
  }
</style>
