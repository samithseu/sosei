---
interface Props {
  pageRange?: string;
}

const { pageRange } = Astro.props;
---

<div class="page-footer custom-footer" data-page-range={pageRange}>
  <slot />
</div>

<style>
  .page-footer {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-areas: "left center right";
    align-items: start;
    padding: 0.5rem 0;
    border-top: 1px solid #e5e5e5;
    font-size: 0.875rem;
    color: #666;
    box-sizing: border-box;
  }
</style>
